{
  "name": "sharpai-rag-server",
  "version": "1.0.0",
  "description": "SharpAI RAG chatbot backend for SharpKode Tech Solutions.",
  "main": "server.js",
  "type": "commonjs",
  "scripts": {
    "start": "node -r ./config.js server.js",
    "dev": "nodemon --exec \"node -r ./config.js server.js\"",
    "reindex": "node -r ./config.js services/rag.js --reindex",
    "index": "npm run reindex",
    "build:vectors": "node scripts/buildVectorStore.js"
  },
  "dependencies": {
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.19.2",
    "express-rate-limit": "^7.4.0",
    "helmet": "^7.1.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.4"
  },
  "engines": {
    "node": ">=18"
  }
}
